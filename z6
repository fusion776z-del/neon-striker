 let room = Math.max(0, MAX_ENEMY_BULLETS - enemyBullets.length);
 if(room <= 0) return;

 // ★ boss scaling
 const bossActive = (boss && !boss.entering);
 const hpRatio = bossActive ? Math.max(0, Math.min(1, boss.hp / boss.maxHP)) : 1;
 const phase = bossActive ? (boss.phase || 1) : 1;
 const speedMul = bossActive ? (1 + (1 - hpRatio) * 0.22 + (phase-1) * 0.05) : 1;

 let pushed = 0;
 for(let i=0;i<batch.length && pushed<room;i++){
  if(skipStep && (i % (skipStep+1)) !== 0) continue;
  const b = batch[i];
  if(!b) continue;

  if(b.boss && bossActive){
   b.vx *= speedMul; b.vy *= speedMul;
   if(phase>=4){
    b.curve = (b.curve != null) ? b.curve : ((i%2===0)? 0.0032 : -0.0032);
    b.wave = b.wave || 1;
    b.seed = (b.seed != null) ? b.seed : (boss.t + i*7);
