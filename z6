function render(){ ctx.save(); const sx=0, sy=0; ctx.translate(sx,sy); drawBackground(time); if(state!=='title' && state!=='ending' && state!=='error') drawTerrains(); drawParticles(); drawExplosions(); if(state==='title') drawTitle(); else if(state==='ending') drawEnding(); else if(state==='error') drawError(); else {
