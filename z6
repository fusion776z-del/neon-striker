x,y:cy,vx:Math.cos(a)*6.2,vy:Math.sin(a)*6.2,w:14,h:5,enemy:true,boss:true,color:'#72f7ff'}); } pushEnemyBullets(batch); boss.shot = Math.max(6, Math.floor(13/getStageDensity())); } } else if(boss.phase===1){ const batch=[]; const load = getBulletLoadScale(); const step = load < 0.65 ? 2 : 1; const span=bossCount(15); for(let k=-Math.floor(span/2);k<=Math.floor(span/2);k+=step){ const ci=(k+15)%BOSS_BULLET_PALETTE.length; batch.push({x:cx,y:cy,vx:-4.9,vy:k*.62,w:12,h:5,enemy:true,boss:true,color:BOSS_BULLET_PALETTE[ci]}); } pushEnemyBullets(batch); boss.shot=Math.max(6, Math.floor((30-stage*4-boss.phase*6) / getStageDensity())); } else if(boss.phase===2){ const load = getBulletLoadScale(); const batch=[]; const step = load < 0.65 ? 2 : 1; const spanA=bossCount(21); for(let a=-Math.floor(spanA/2);a<=Math.floor(spanA/2);a+=step){ const ci=(a+20)%BOSS_BULLET_PALETTE.length; batch.push({x:cx,y:cy,vx:Math.cos(Math.PI + a*.11)*5.6,vy:Math.sin(Math.PI + a*.11)*5.6,w:10,h:5,enemy:true,boss:true,color:BOSS_BULLET_PALETTE[ci]}); } for(let yy=48, idx=0; yy<H-48; yy+=56*(load < 0.8 ? 2 : 1), idx++) batch.push({x:cx,y:yy,vx:-6.4,vy:0,w:16,h:6,enemy:true,boss:true,color:BOSS_BULLET_PALETTE[idx % BOSS_BULLET_PALETTE.length]}); pushEnemyBullets(batch); boss.shot=Math.max(6, Math.floor((30-stage*4-boss.phase*6) / getStageDensity())); } else { const load = getBulletLoadScale(); const rings = bossCount(load < 0.65 ? 2 : 3); const perRing = bossCount(load < 0.65 ? 14 : load < 0.8 ? 18 : 24); const batch=[]; for(let ring=0; ring<rings; ring++){ for(let a=0;a<perRing;a++){ const div=Math.max(1,perRing-1); const ang=Math.PI + (a/div-.5)*2.05 + ring*.05; const ci=(a + ring*2) % BOSS_BULLET_PALETTE.length; batch.push({x:cx,y:cy,vx:Math.cos(ang)*(4.6+ring*0.9),vy:Math.sin(ang)*(4.6+ring*0.9),w:10,h:5,enemy:true,boss:true,color:BOSS_BULLET_PALETTE[ci]}); } } pushEnemyBullets(batch); boss.shot=Math.max(6, Math.floor((30-stage*4-boss.phase*6) / getStageDensity())); } } const p=getPlayerHitbox()