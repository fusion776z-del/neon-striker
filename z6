// === iPhone UX helpers v2 (compact joystick/buttons) ===
(function(){
  const diag = document.getElementById('diag');
  const show = (msg)=>{ if(!diag) return; diag.style.display='block'; diag.textContent = msg; };
  window.addEventListener('error', (e)=>{ show('JS ERROR:\n' + (e.message||e.error||e)); });
  window.addEventListener('unhandledrejection', (e)=>{ show('PROMISE ERROR:\n' + (e.reason||e)); });

  const prevent = (ev)=>ev.preventDefault();
  [cvs, document.getElementById('joystick'), document.querySelector('.actions')].forEach(el=>{
    if(!el) return;
    el.addEventListener('touchstart', prevent, {passive:false});
    el.addEventListener('touchmove',  prevent, {passive:false});
    el.addEventListener('touchend',   prevent, {passive:false});
  });

  // Landscape overlay
  const rh = document.getElementById('rotateHint');
  const isLand = ()=> (window.matchMedia && window.matchMedia('(orientation: landscape)').matches) || (innerWidth > innerHeight);
  const upd = ()=>{
    const land = isLand();
    if(rh) rh.style.display = land ? 'none' : 'grid';
    if(!land && state==='play' && clearTimer<=0){ paused = true; }
  };
  addEventListener('resize', upd);
  addEventListener('orientationchange', upd);
  upd();

  // Virtual joystick (smaller)
  const joy = document.getElementById('joystick');
  const stick = document.getElementById('stick');
  let active = false, pid = null, cx=0, cy=0;
  const R = 36; // smaller radius -> easier thumb reach
  const dead = 0.12;
  const setStick = (dx,dy)=>{ if(!stick) return; stick.style.transform = `translate(${dx - 24}px, ${dy - 24}px)`; };
  const reset = ()=>{ input.ax = 0; input.ay = 0; active=false; pid=null; setStick(0,0); };
  const center = ()=>{ if(!joy) return; const r=joy.getBoundingClientRect(); cx=r.left+r.width/2; cy=r.top+r.height/2; };

  const down = (e)=>{ if(!joy) return; e.preventDefault(); resumeAudio(); active=true; pid=e.pointerId; center(); joy.setPointerCapture(pid); };
  const move = (e)=>{
    if(!active || e.pointerId!==pid) return;
    e.preventDefault();
    let dx=e.clientX-cx, dy=e.clientY-cy;
    const dist=Math.hypot(dx,dy)||1;
    if(dist>R){ const s=R/dist; dx*=s; dy*=s; }
    let nx=dx/R, ny=dy/R;
    if(Math.abs(nx)<dead) nx=0;
    if(Math.abs(ny)<dead) ny=0;
    input.ax = nx;
    input.ay = ny;
    setStick(dx,dy);
  };
  const up = (e)=>{ if(e.pointerId!==pid) return; e.preventDefault(); reset(); };

  if(joy){
    joy.addEventListener('pointerdown', down);
    joy.addEventListener('pointermove', move);
    joy.addEventListener('pointerup', up);
    joy.addEventListener('pointercancel', up);
    addEventListener('resize', center);
    addEventListener('orientationchange', center);
  }

  // Action buttons
  const setActive = (el,on)=> el && el.classList.toggle('active', !!on);
  const actions = document.querySelector('.actions');
 // Also bind standalone focus button (above joystick)
 const focusBtn = document.getElementById('focusBtn');
 if(focusBtn && focusBtn.getAttribute('data-hold')==='focus'){
   const onDown = (e)=>{ e.preventDefault(); resumeAudio(); input.focus=1; setActive(focusBtn,true); };
   const onUp = (e)=>{ e.preventDefault(); input.focus=0; setActive(focusBtn,false); };
   focusBtn.addEventListener('pointerdown', onDown);
   focusBtn.addEventListener('pointerup', onUp);
   focusBtn.addEventListener('pointercancel', onUp);
   focusBtn.addEventListener('pointerleave', (e)=>{ if(e.buttons===1) onUp(e); });
 }
  if(actions){
    actions.querySelectorAll('[data-hold]').forEach(btn=>{
      const k = btn.getAttribute('data-hold');
      const onDown = (e)=>{ e.preventDefault(); resumeAudio(); if(k==='shot') input.shot=1; if(k==='laser') input.alt=1; if(k==='focus') input.focus=1; setActive(btn,true); };
