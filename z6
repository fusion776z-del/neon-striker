  }

  enemyBullets.push(b);
  pushed++; room--; if(room<=0) break;

  if(b.boss && bossActive && phase>=3 && room>0){
   const ang = Math.atan2(b.vy, b.vx);
   const spd = Math.hypot(b.vx, b.vy) || 1;
   const spread = phase>=4 ? 0.11 : 0.08;
   const copies = phase>=4 ? 2 : 1;
   for(let c=0;c<copies && room>0;c++){
    const dir = (c%2===0) ? 1 : -1;
    const a2 = ang + dir*spread;
    const nb = Object.assign({}, b);
    nb.vx = Math.cos(a2)*spd;
    nb.vy = Math.sin(a2)*spd;
    nb.w = Math.max(6, Math.floor((b.w||10)*0.88));
    nb.h = Math.max(4, Math.floor((b.h||5)*0.88));
    if(phase>=4){
     nb.curve = (dir>0)?0.0026:-0.0026;
     nb.wave = 1;
     nb.seed = (b.seed||0) + 13 + c*11;
    }
    enemyBullets.push(nb);
    pushed++; room--;
   }
  }
 }
}
