 if(audioCtx.state !== 'running') return;
 bgmStage = stage || 1;
 bgmBoss = !!isBoss;
 // ★ 約20秒固定ループ（アルペジオ維持）
 const LOOP_BARS = 8;
 bgmBus = createBgmBus(isBoss ? 0.27 : 0.20);
 bgmNextTime = audioCtx.currentTime + 0.07;
 bgmBar = 0;
 const baseBpm = isBoss ? 150 : 140;
 bgmTimer = setInterval(() => {
  if(audioCtx.state !== 'running' || !bgmBus) return;
  const step = 60 / baseBpm / 4;
  while(bgmNextTime < audioCtx.currentTime + 0.42){
   playBar(bgmBar % LOOP_BARS, bgmNextTime, step, bgmStage, bgmBoss);
   bgmNextTime += step * 16;
   bgmBar = (bgmBar + 1) % LOOP_BARS;
  }
 }, 25);
}


