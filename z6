      btn.addEventListener('pointerdown', onDown);
      btn.addEventListener('pointerup', onUp);
      btn.addEventListener('pointercancel', onUp);
      btn.addEventListener('pointerleave', (e)=>{ if(e.buttons===1) onUp(e); });
    });

    actions.querySelectorAll('[data-tap]').forEach(btn=>{
      const k = btn.getAttribute('data-tap');
      btn.addEventListener('pointerdown', (e)=>{ e.preventDefault(); resumeAudio(); setActive(btn,true); });
      btn.addEventListener('pointerup', (e)=>{
        e.preventDefault();
        if(k==='bomb') input.bomb = 1;
        if(k==='pause'){
          if(state==='play' && clearTimer<=0){ paused = !paused; }
          resumeAudio();
        }
        setActive(btn,false);
      });
      btn.addEventListener('pointercancel', (e)=>{ e.preventDefault(); setActive(btn,false); });
    });
  }

  // Tap canvas to start on title
  cvs.addEventListener('pointerdown', ()=>{ resumeAudio(); if(state==='title') input.shot=1; });
  cvs.addEventListener('pointerup',   ()=>{ if(state==='title') input.shot=0; });
})();

